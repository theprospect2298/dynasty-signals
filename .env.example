PORT=3000
JWT_SECRET=change_this_to_a_long_random_string_in_production
STRIPE_SECRET_KEY=sk_test_your_stripe_secret_key_here
STRIPE_WEBHOOK_SECRET=whsec_your_webhook_secret_here
PLATFORM_FEE_PCT=0.15

# Public URL of the app — used in notification emails
APP_URL=https://your-app.replit.app

# Web push (optional — keys are auto-generated into server/vapid.json if omitted)
VAPID_PUBLIC_KEY=
VAPID_PRIVATE_KEY=
VAPID_CONTACT=you@example.com

# Email notifications via SMTP (emails are skipped if not configured)
# Gmail: use an App Password — myaccount.google.com/apppasswords
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=you@gmail.com
SMTP_PASS=your_app_password_here
EMAIL_FROM="Dynasty Signals <you@gmail.com>"
